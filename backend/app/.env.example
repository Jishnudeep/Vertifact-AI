# ─────────────────────────────────────────────────────────────
# VeriFact AI — backend environment template
# Copy this file to `.env` in the same directory and fill in values:
#     cp backend/app/.env.example backend/app/.env
# The real `.env` is gitignored — never commit secrets. Keys load via
# app/config.py (Pydantic Settings); all external calls stay server-side.
# ─────────────────────────────────────────────────────────────

# ── Supabase (Postgres + pgvector) ─────────────────────────────
# Project URL + keys from: Supabase dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISH_KEY=your-supabase-publishable-anon-key
SUPABASE_SECRET_KEY=your-supabase-secret-service-role-key

# ── LLM inference (Groq, free tier) ────────────────────────────
# Create a key at: https://console.groq.com
GROQ_API_KEY=gsk_your-groq-api-key

# ── Web search (Tavily, 1k req/month free) ─────────────────────
# Sign up at: https://tavily.com
TAVILY_API_KEY=tvly-your-tavily-api-key

# ── Fact-check lookup (Google Fact Check Tools API) ────────────
# Google Cloud Console → enable "Fact Check Tools API" → create API key
GOOGLE_FACTCHECK_API_KEY=your-google-fact-check-api-key

# ── Optional overrides (have sensible defaults in app/config.py) ─
# Model id is always read from config — swap providers/models here, not in code.
# MODEL_ID=groq/llama-3.1-8b-instant
# Embedding dimension: 384 (all-MiniLM-L6-v2, dev) or 1024 (BGE-M3, prod).
# Must match the pgvector column dimension in the DB schema.
# EMBEDDING_DIMENSION=384
