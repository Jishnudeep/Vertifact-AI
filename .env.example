# ─────────────────────────────────────────────────────────────
# VeriFact AI — environment template
# Copy to `.env` (never commit the real .env) and fill in your keys.
# Loaded server-side via backend/app/config.py (Pydantic Settings).
# ─────────────────────────────────────────────────────────────

# ── Supabase (Postgres + pgvector) ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISH_KEY=your-supabase-anon-publishable-key
SUPABASE_SECRET_KEY=your-supabase-service-secret-key

# ── LLM inference (dev: Groq, free tier) ──
GROQ_API_KEY=your-groq-api-key

# ── Search & fact-checking ──
# Google Fact Check Tools API is FREE (API key from Google Cloud Console).
GOOGLE_FACTCHECK_API_KEY=your-google-fact-check-api-key
TAVILY_API_KEY=your-tavily-api-key

# ── Optional overrides (defaults shown) ──
# Model is swapped via config, never hardcoded in agent logic.
# MODEL_ID=groq/llama-3.1-8b-instant
# Embedding dimension: 384 = all-MiniLM-L6-v2 (dev), 1024 = BAAI/bge-m3 (prod).
# EMBEDDING_DIMENSION=384
